---
import ProyectsCard from "../../../features/projects/components/ProyectsCard.astro";

const Projects = [
  {
    title: "Busca Repuestos",
    description: "Plataforma de e-commerce para repuestos automotrices. El desafío era integrar múltiples proveedores con inventarios desatualizados. Elegí una arquitectura orientada a eventos para actualizar stock en tiempo real sin bloquear al usuario. Implementé cache en Redis para reducir latencia de API en un 70%.",
    image: "/images/project_busca_repuestos.webp",
    technologies: [
      { id: 1, name: "Next.js", desing: { class: "" } },
      { id: 2, name: "Node.js", desing: { class: "" } },
      { id: 3, name: "PostgreSQL", desing: { class: "" } },
    ],
  },
  {
    title: "Sistema ETL Automatizado",
    description: "Pipeline de datos para reportes de RRHH. El problema: procesos manuales con 8 horas/semana y errores recurrentes. Diseñé una arquitectura serverless con AWS Lambda que se ejecuta solo cuando hay datos nuevos, optimizando costos. Reduje el tiempo de generación de 8 horas a 3 minutos.",
    image: "/images/project_etl.webp",
    technologies: [
      { id: 1, name: "Python", desing: { class: "" } },
      { id: 2, name: "AWS", desing: { class: "" } },
    ],
  },
  {
    title: "S&G Propiedades",
    description: "Landing page para inmobiliaria. El negocio necesitaba generar leads cualificados rápido. Prioricé Core Web Vitals sobre diseño visual. Elegí Astro por su estrategia 'islands' para mínimo JavaScript, resultando en Lighthouse score de 98 y 50% más leads.",
    image: "/images/sygpropiedades.avif",
    technologies: [
      { id: 1, name: "Astro", desing: { class: "" } },
      { id: 2, name: "TypeScript", desing: { class: "" } },
      { id: 3, name: "Tailwind", desing: { class: "" } },
    ],
  },
  {
    title: "Duarte y Leiva",
    description: "Web para despacho legal. El reto era transmitir profesionalismo sin cargar el sitio. Implementé forms as a service con validación en cliente y servidor. El trade-off: más código inicial vs. experiencia de usuario fluida. Resultado: 40% increase en consultas.",
    image: "/images/duarteyleiva.webp",
    technologies: [
      { id: 1, name: "Astro", desing: { class: "" } },
      { id: 2, name: "TypeScript", desing: { class: "" } },
      { id: 3, name: "Tailwind", desing: { class: "" } },
    ],
  },
  {
    title: "UV Tracker App",
    description: "App Android para radiación UV. Integré API de MeteoChile con caching inteligente para funcionar offline. El trade-off: datos en tiempo real vs. batería. Implementé polling adaptativo que extiende autonomía un 60%.",
    image: "/images/radiationUV.webp",
    technologies: [
      { id: 1, name: "Android", desing: { class: "" } },
      { id: 2, name: "Java", desing: { class: "" } },
    ],
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  {Projects.map((project, index) => (
    <ProyectsCard {...project} index={index} />
  ))}
</div>