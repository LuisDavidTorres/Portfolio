---
interface Props {
  conpany: string;
  date: string;
  position: string;
  description: string;
}

const { conpany, date, position, description } = Astro.props;
---

<div class="border-l-2 border-neutral-200 dark:border-neutral-800 pl-6 pb-12 last:pb-0">
  <time class="text-sm text-neutral-500 dark:text-neutral-400">{date}</time>
  <h3 class="text-lg font-semibold text-neutral-900 dark:text-white mt-1">
    {position}
  </h3>
  <p class="text-sm font-medium text-neutral-500 dark:text-neutral-400 mt-1">
    {conpany}
  </p>
  <p class="text-neutral-600 dark:text-neutral-300 mt-3 leading-relaxed">
    {description}
  </p>
</div>