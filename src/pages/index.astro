---
import Layout from "../layouts/Layout.astro";
import SectionContainer from "../shared/components/SectionContainer.astro";
import Hero from "../features/hero/components/Hero.astro";
import ProyectsGrid from "../shared/components/grids/ProyectsGrid.astro";
import SkillsSection from "../features/skills/SkillsSection.astro";
import ContactForm from "../features/contact/components/ContactForm";
import ExperienceTimeline from "../shared/components/timeline/ExperienceTimeline.astro";
---

<Layout
  title="David Phillips | Full Stack Developer"
  description="Desarrollador Full Stack especializado en crear experiencias web modernas y soluciones digitales innovadoras."
>
  <main>
    <Hero />

    <SectionContainer>
      <div id="experience" class="mb-16 scroll-mt-24">
        <h2 class="text-3xl sm:text-4xl font-semibold text-neutral-900 dark:text-white">
          Experiencia
        </h2>
      </div>
      <ExperienceTimeline />
    </SectionContainer>

    <SectionContainer>
      <div id="projects" class="mb-16 scroll-mt-24">
        <h2 class="text-3xl sm:text-4xl font-semibold text-neutral-900 dark:text-white">
          Proyectos
        </h2>
      </div>
      <ProyectsGrid />
    </SectionContainer>

    <SectionContainer>
      <div id="skills" class="mb-16 scroll-mt-24">
        <h2 class="text-3xl sm:text-4xl font-semibold text-neutral-900 dark:text-white">
          Tecnologías
        </h2>
      </div>
      <SkillsSection />
    </SectionContainer>

    <SectionContainer>
      <div id="contact" class="mb-16 scroll-mt-24">
        <h2 class="text-3xl sm:text-4xl font-semibold text-neutral-900 dark:text-white">
          Contacto
        </h2>
      </div>
      <ContactForm client:load />
    </SectionContainer>
  </main>
</Layout>

<style>
  main {
    overflow-x: hidden;
  }
</style>
