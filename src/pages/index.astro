---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import Briefcase from "../components/icons/Briefcase.astro";
import Code from "../components/icons/Code.astro";
import Gear from "../components/icons/Gear.astro";
import ExperienceTimeline from "../components/timeline/ExperienceTimeline.astro";
import SectionContainer from "../components/SectionContainer.astro";
import SectionContainerPrincipal from "../components/SectionContainerPrincipal.astro";
import ProyectsGrid from "../components/grids/ProyectsGrid.astro";
import SkillsSection from "../features/skills/SkillsSection.astro";
import ContactForm from "../components/forms/ContactForm";
import ArrowDown from "../components/icons/ArrowDown";
import DownloadCv from "../components/buttons/DownLoadCv";
---

<Layout
  title="Desarrollador Web en Chile | Páginas Web Profesionales y Automatización de Procesos - Luis Phillips"
  description="Daviic, desarrollador web en Chile. Diseño páginas web modernas y automatizo procesos repetitivos para aumentar la eficiencia de tu negocio."
>
  <main
    class="relative min-h-screen text-white"
  >
    <!-- Efectos de fondo decorativos -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 right-10 w-96 h-96 bg-green-custom/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-40 left-20 w-80 h-80 bg-green-custom/3 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/3 w-2 h-2 bg-green-custom/40 rounded-full animate-pulse"></div>
      <div class="absolute top-1/3 right-1/4 w-1 h-1 bg-green-custom/30 rounded-full animate-pulse" style="animation-delay: 1s;"></div>
      <div class="absolute bottom-1/3 right-1/3 w-1.5 h-1.5 bg-green-custom/20 rounded-full animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <SectionContainerPrincipal>
      <div class="relative z-10">
        <!-- Texto decorativo en el fondo -->
        <div class="absolute -top-10 sm:-top-20 -left-5 sm:-left-10 text-[120px] sm:text-[180px] md:text-[280px] font-bold text-white/[0.02] select-none pointer-events-none leading-none">
          DEV
        </div>

        <div class="flex flex-col items-start mb-6 sm:mb-8">
          <p class="text-green-custom text-xs sm:text-sm font-mono mb-3 sm:mb-4 animate-fade-in-up">👋 Hola! Soy</p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-tight animate-fade-in-up" style="animation-delay: 0.1s;">
            David Phillips
          </h1>
          <p class="text-xl sm:text-2xl md:text-3xl lg:text-4xl text-gray-500 mt-2 animate-fade-in-up" style="animation-delay: 0.2s;">
            Desarrollador Full Stack
          </p>
        </div>

        <div class="flex mt-4 mb-4 sm:mb-6 animate-fade-in-up" style="animation-delay: 0.3s;">
          <Badge>Disponible para trabajar</Badge>
        </div>

        <div class="max-w-2xl space-y-3 sm:space-y-4 animate-fade-in-up" style="animation-delay: 0.4s;">
          <p class="text-base sm:text-lg lg:text-xl text-gray-400 leading-relaxed">
            Ingeniero Informático con más de un año de experiencia creando soluciones digitales. 
            Residente en <span class="text-green-custom">La Serena, Chile</span>.
          </p>
          <p class="text-sm sm:text-base lg:text-lg text-gray-500 leading-relaxed">
            Me especializo en <span class="text-green-custom font-medium">crear sitios web únicos</span> y en 
            <span class="text-green-custom font-medium">automatizar procesos repetitivos</span> para mejorar 
            la eficiencia y productividad en diferentes áreas.
          </p>
        </div>

        <!-- Stats o métricas -->
        <div class="flex flex-wrap gap-6 sm:gap-8 mt-8 sm:mt-12 animate-fade-in-up" style="animation-delay: 0.5s;">
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-green-custom">1+</p>
            <p class="text-xs sm:text-sm text-gray-500 uppercase tracking-wider">Años de experiencia</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-green-custom">15+</p>
            <p class="text-xs sm:text-sm text-gray-500 uppercase tracking-wider">Proyectos completados</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-green-custom">10+</p>
            <p class="text-xs sm:text-sm text-gray-500 uppercase tracking-wider">Tecnologías</p>
          </div>
        </div>

        <section class="mt-8 sm:mt-12 lg:mt-16 animate-fade-in-up" style="animation-delay: 0.6s;">
          <DownloadCv />
        </section>
      </div>

      <section
        id="more"
        class="mt-16 sm:mt-20 lg:mt-24 w-full flex flex-col justify-center items-center cursor-pointer text-gray-500 hover:text-green-custom transition-all duration-300"
      >
        <span class="mb-2 text-sm">Descubre más</span>
        <ArrowDown />
      </section>
    </SectionContainerPrincipal>
    <SectionContainer>
      <div id="experience" class="mb-12 scroll-mt-24">
        <div class="flex items-center gap-x-4 mb-4">
          <span class="text-green-custom/70 text-sm font-mono">01</span>
          <div class="h-px w-12 bg-gradient-to-r from-green-custom/40 to-transparent"></div>
        </div>
        <h2 class="text-5xl md:text-6xl font-bold text-white mb-16">
          Experiencia
        </h2>
      </div>
      <ExperienceTimeline />
    </SectionContainer>
    <SectionContainer>
      <div id="projects" class="mb-12 scroll-mt-24">
        <div class="flex items-center gap-x-4 mb-4">
          <span class="text-green-custom/70 text-sm font-mono">02</span>
          <div class="h-px w-12 bg-gradient-to-r from-green-custom/40 to-transparent"></div>
        </div>
        <h2 class="text-5xl md:text-6xl font-bold text-white mb-16">
          Proyectos
        </h2>
      </div>
      <ProyectsGrid />
    </SectionContainer>
    <SectionContainer>
      <div id="skills" class="mb-12 scroll-mt-24">
        <div class="flex items-center gap-x-4 mb-4">
          <span class="text-green-custom/70 text-sm font-mono">03</span>
          <div class="h-px w-12 bg-gradient-to-r from-green-custom/40 to-transparent"></div>
        </div>
        <h2 class="text-5xl md:text-6xl font-bold text-white mb-16">
          Habilidades
        </h2>
      </div>
      <SkillsSection />
    </SectionContainer>
    <SectionContainer>
      <ContactForm client:load />
    </SectionContainer>
  </main>
  <script src="../scripts/scrollToSection"></script>
</Layout>
