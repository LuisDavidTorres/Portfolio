---
import { Image } from 'astro:assets';
import BadgesTechnologies from "../../../shared/components/badges/BadgesTechnologies.astro";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  index?: number;
  technologies: {
    id: number;
    name: string;
    desing: {
      class: string;
    };
  }[];
}

const { title, description, image, technologies, index = 0 } = Astro.props;
---

<article class="group cursor-pointer">
  <div class="relative overflow-hidden rounded-2xl bg-neutral-100 dark:bg-slate-800 aspect-video mb-6">
    <Image
      src={image}
      alt={title}
      widths={[360, 540, 720]}
      sizes="(max-width: 768px) 100vw, 50vw"
      format="avif"
      quality={75}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </div>
  
  <div class="space-y-3">
    <h3 class="text-xl font-semibold text-neutral-900 dark:text-slate-50 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
      {title}
    </h3>
    
    <p class="text-neutral-600 dark:text-slate-200 text-sm leading-relaxed">
      {description}
    </p>
    
    <div class="flex flex-wrap gap-2 pt-2">
      {technologies.map((tech) => (
        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-neutral-200 dark:bg-slate-700 text-neutral-600 dark:text-slate-100">
          {tech.name}
        </span>
      ))}
    </div>
  </div>
</article>