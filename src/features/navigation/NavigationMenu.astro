---
import { NAV_ITEMS } from "./constants/navItems";
---

<nav id="desktop-nav" class="hidden md:flex items-center gap-6 md:gap-8 text-sm">
  {NAV_ITEMS.map((item) => (
    <a
      href={item.url}
      data-nav-desktop
      class="font-medium transition-colors duration-200 text-neutral-600 dark:text-slate-300 hover:text-neutral-900 dark:hover:text-slate-50"
    >
      {item.title}
    </a>
  ))}
</nav>

<script>
  const links = document.querySelectorAll('[data-nav-desktop]') as NodeListOf<HTMLAnchorElement>;
  const items = Array.from(links);

  function updateActive() {
    const scrollPos = window.scrollY;
    const winH = window.innerHeight;
    const docH = document.documentElement.scrollHeight;

    if (scrollPos < 400) {
      items.forEach((l) => {
        l.classList.remove('text-neutral-900', 'dark:text-slate-100');
        l.classList.add('text-neutral-600', 'dark:text-slate-300');
      });
      return;
    }

    let activeUrl = '';
    if (scrollPos + winH >= docH - 200) {
      activeUrl = items[items.length - 1]?.getAttribute('href') || '';
    } else {
      for (const link of items) {
        const href = link.getAttribute('href') || '';
        const section = document.querySelector(href);
        if (section) {
          const rect = section.getBoundingClientRect();
          if (rect.top <= 200 && rect.bottom > 100) {
            activeUrl = href;
            break;
          }
        }
      }
    }

    items.forEach((l) => {
      const href = l.getAttribute('href') || '';
      if (href === activeUrl) {
        l.classList.add('text-neutral-900', 'dark:text-slate-100');
        l.classList.remove('text-neutral-600', 'dark:text-slate-300');
      } else {
        l.classList.remove('text-neutral-900', 'dark:text-slate-100');
        l.classList.add('text-neutral-600', 'dark:text-slate-300');
      }
    });
  }

  updateActive();
  window.addEventListener('scroll', updateActive, { passive: true });
</script>
