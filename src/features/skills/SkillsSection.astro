---
import { SKILLS, type SkillCategory } from "./constants/skills";
import SkillCard from "./components/SkillCard.astro";

const categories: { id: SkillCategory; title: string }[] = [
  { id: "frontend", title: "Frontend" },
  { id: "backend", title: "Backend" },
  { id: "other", title: "Herramientas & Otros" }
];
---

<div class="flex flex-col gap-10 lg:gap-14 w-full">
  {categories.map((category) => {
    const categorySkills = SKILLS.filter(s => s.category === category.id);
    if (categorySkills.length === 0) return null;
    
    return (
      <div class="flex flex-col gap-6">
        <div class="flex items-center gap-4">
          <h3 class="text-lg md:text-xl font-medium text-neutral-800 dark:text-slate-100 whitespace-nowrap">
            {category.title}
          </h3>
          <div class="h-[1px] flex-1 bg-neutral-200 dark:bg-slate-800"></div>
        </div>
        
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {categorySkills.map((skill) => {
            const Icon = skill.icon;
            return (
              <SkillCard name={skill.name}>
                <Icon />
              </SkillCard>
            );
          })}
        </div>
      </div>
    );
  })}
</div>