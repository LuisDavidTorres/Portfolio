---
import { SKILLS } from "./constants/skills";
import SkillCard from "./components/SkillCard.astro";
---

<div class="mt-8">
  <!-- Descripción -->
  <p class="text-gray-400 mb-8 max-w-3xl text-center mx-auto">
    Me apasiona trabajar con diferentes tecnologías para crear soluciones completas. 
    Desde interfaces que conectan con los usuarios hasta sistemas backend que hacen que todo funcione de manera eficiente.
  </p>

  <!-- Pestañas -->
  <div class="flex flex-wrap justify-center gap-3 mb-8">
    <button 
      class="tab-btn active px-6 py-2.5 rounded-lg font-medium transition-all duration-300 text-sm"
      data-category="all"
    >
      Todas
    </button>
    <button 
      class="tab-btn px-6 py-2.5 rounded-lg font-medium transition-all duration-300 text-sm"
      data-category="frontend"
    >
      Frontend
    </button>
    <button 
      class="tab-btn px-6 py-2.5 rounded-lg font-medium transition-all duration-300 text-sm"
      data-category="backend"
    >
      Backend
    </button>
    <button 
      class="tab-btn px-6 py-2.5 rounded-lg font-medium transition-all duration-300 text-sm"
      data-category="other"
    >
      Otros
    </button>
  </div>

  <!-- Grid de Skills -->
  <div class="relative bg-gradient-to-br from-zinc-900/50 to-black/50 border border-zinc-800/50 rounded-2xl p-8 md:p-12 backdrop-blur-sm transition-all duration-500">
    <!-- Efecto de rayas diagonales sutil en las esquinas -->
    <div class="absolute top-0 left-0 w-32 h-32 opacity-10 overflow-hidden rounded-tl-2xl">
      <div class="absolute inset-0 bg-gradient-to-br from-green-custom to-transparent transform rotate-45" style="background-size: 20px 20px; background-image: repeating-linear-gradient(45deg, #0bff84 0px, #0bff84 10px, transparent 10px, transparent 20px);"></div>
    </div>
    <div class="absolute bottom-0 right-0 w-32 h-32 opacity-10 overflow-hidden rounded-br-2xl">
      <div class="absolute inset-0 bg-gradient-to-tl from-green-custom to-transparent transform -rotate-45" style="background-size: 20px 20px; background-image: repeating-linear-gradient(45deg, #0bff84 0px, #0bff84 10px, transparent 10px, transparent 20px);"></div>
    </div>

    <div id="skills-grid" class="flex flex-wrap justify-center gap-6 relative z-10 items-start">
      {SKILLS.map((skill, index) => {
        const Icon = skill.icon;
        return (
          <div 
            data-category={skill.category} 
            class="skill-item"
          >
            <SkillCard>
              <Icon />
            </SkillCard>
          </div>
        );
      })}
    </div>
  </div>
</div>

<style>
  .tab-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #9ca3af;
  }
  
  .tab-btn:hover {
    background: rgba(11, 255, 132, 0.1);
    border-color: rgba(11, 255, 132, 0.3);
    color: #0bff84;
  }
  
  .tab-btn.active {
    background: linear-gradient(135deg, rgba(11, 255, 132, 0.2), rgba(11, 255, 132, 0.1));
    border-color: #0bff84;
    color: #0bff84;
    box-shadow: 0 0 20px rgba(11, 255, 132, 0.2);
  }

  .skill-item {
    opacity: 1;
    transform: scale(1);
    flex: 0 0 auto;
    transition: opacity 0.4s ease, transform 0.4s ease, width 0.4s ease, margin 0.4s ease;
  }

  .skill-item.hidden {
    opacity: 0;
    transform: scale(0);
    width: 0;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const skills = document.querySelectorAll('.skill-item');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const category = tab.getAttribute('data-category');
        
        // Actualizar tabs activos
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        // Filtrar con transición suave
        skills.forEach((skill) => {
          const skillCategory = skill.getAttribute('data-category');
          const shouldShow = category === 'all' || skillCategory === category;
          
          if (shouldShow) {
            skill.classList.remove('hidden');
          } else {
            skill.classList.add('hidden');
          }
        });
      });
    });
  });
</script>