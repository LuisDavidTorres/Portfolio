---
interface Props {
  name: string;
}

const { name } = Astro.props;
---
<div class="group flex items-center gap-4 px-4 py-3.5 bg-white border border-neutral-200 rounded-xl hover:bg-neutral-50 hover:border-neutral-300 dark:bg-slate-900/40 dark:border-slate-800/80 dark:hover:bg-slate-800 dark:hover:border-slate-700 transition-all duration-300 cursor-default">
  <div class="flex items-center justify-center w-7 h-7 group-hover:scale-110 transition-all duration-300 icon-container">
    <slot />
  </div>
  <span class="text-sm font-medium text-neutral-600 dark:text-slate-400 group-hover:text-neutral-900 dark:group-hover:text-slate-200 transition-colors duration-300">
    {name}
  </span>
</div>

<style>
  .icon-container :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>